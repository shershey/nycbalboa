---
import Layout from '../layouts/Layout.astro';
const BASE_URL = 'https://calendar.google.com/calendar/embed?src=cca341fd504d87e8bdc5d22fa803d7237b5d8ad34696729ca076f27f7c36881d%40group.calendar.google.com&ctz=America%2FNew_York';
---
<Layout title="Events — NYC Balboa">
  <h1>Events</h1>
  <div class="calendar-wrap">
    <iframe
      id="cal"
      src={`${BASE_URL}&mode=MONTH`}
      style="border: 0"
      width="100%"
      height="600"
      frameborder="0"
      scrolling="no"
    ></iframe>
  </div>
</Layout>

<script define:vars={{ BASE_URL }}>
  const iframe = document.getElementById('cal');
  const mode = window.innerWidth < 640 ? 'AGENDA' : 'MONTH';
  iframe.src = `${BASE_URL}&mode=${mode}`;
</script>

<style is:global>
  .calendar-wrap {
    width: 100%;
    overflow: hidden;
    border: 2px solid #8a6a3a;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), 0 1px 3px rgba(0, 0, 0, 0.06);
  }
</style>
