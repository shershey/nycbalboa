---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Events — NYC Balboa">
  <h1>Events</h1>
  <div class="calendar-wrap">
    <iframe
      src="https://calendar.google.com/calendar/embed?src=cca341fd504d87e8bdc5d22fa803d7237b5d8ad34696729ca076f27f7c36881d%40group.calendar.google.com&ctz=America%2FNew_York"
      style="border: 0"
      width="100%"
      height="600"
      frameborder="0"
      scrolling="no"
    ></iframe>
  </div>
</Layout>

<style is:global>
  .calendar-wrap {
    width: 100%;
    overflow: hidden;
    border: 2px solid #8a6a3a;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), 0 1px 3px rgba(0, 0, 0, 0.06);
  }
</style>
