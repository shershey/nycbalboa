---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #f7f2ea;
        color: #1e1a16;
        font-family: 'Source Sans 3', Georgia, sans-serif;
        font-size: 1.05rem;
        line-height: 1.6;
        min-height: 100vh;
      }

      header {
        background: #1e1a16;
        color: #f7f2ea;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      header a.site-name {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.5rem;
        color: #e8c97e;
        text-decoration: none;
        letter-spacing: 0.02em;
      }

      nav {
        display: flex;
        gap: 1.5rem;
      }

      nav a {
        color: #f7f2ea;
        text-decoration: none;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        opacity: 0.85;
        transition: opacity 0.15s;
      }

      nav a:hover { opacity: 1; }

      main {
        max-width: 48rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2.25rem;
        color: #1e1a16;
        margin-bottom: 1.5rem;
        line-height: 1.2;
      }

      h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.35rem;
        color: #5a3e1b;
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.35rem;
        border-bottom: 1px solid #d4c4a0;
      }

      a {
        color: #7a4f1e;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      a:hover { color: #5a3e1b; }

      p { margin-top: 0.35rem; }

      footer {
        text-align: center;
        padding: 2rem 1rem;
        font-size: 0.85rem;
        color: #8a7a66;
        border-top: 1px solid #d4c4a0;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="site-name">NYC Balboa</a>
      <nav>
        <a href="/">Home</a>
        <a href="/offerings">Offerings</a>
        <a href="/events">Events</a>
        <a href="/resources">Resources</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>NYC Balboa &mdash; swing dancing in New York City</footer>
  </body>
</html>
